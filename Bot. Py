class JarvisAI:
    def __init__(self):
        self.headers = {"Authorization": f"Bearer {HF_API_TOKEN}"}

    def query_text(self, prompt: str) -> str:
        """DeepSeek মডেল ব্যবহার করে বুদ্ধিমত্তার সাথে উত্তর দেয়"""
        payload = {
            'model': CHAT_MODEL,
            'messages': [
                # এখানে আপনার দেওয়া সালামটি সিস্টেম প্রম্পটে যুক্ত করা হয়েছে
                {'role': 'system', 'content': 'You are JARVIS. Always start your response with "আসসালামু আলাইকুম, স্যার।". Respond in Bengali and keep it polite and professional.'},
                {'role': 'user', 'content': prompt}
            ],
            'max_tokens': 500
        }
        for _ in range(3):
            try:
                response = requests.post(CHAT_API_URL, headers=self.headers, json=payload, timeout=30)
                response.raise_for_status()
                return response.json()['choices'][0]['message']['content'].strip()
            except Exception as e:
                log.error(f"Text AI Error: {e}")
                time.sleep(2)
        return "😊 দুঃখিত স্যার, সার্ভারে সমস্যা হচ্ছে। একটু পর চেষ্টা করুন।"

    def query_vision(self, image_bytes: bytes, caption: str) -> str:
        """ছবি দেখে সেটি শনাক্ত করে ব্যাখ্যা দেয়"""
        for _ in range(3):
            try:
                resp = requests.post(VISION_API_URL, headers=self.headers, data=image_bytes, timeout=40)
                resp.raise_for_status()
                result = resp.json()
                label = result[0]['label'] if isinstance(result, list) else "অজানা বস্তু"
                
                prompt = f"User sent an image with caption '{caption}'. Analysis shows it is '{label}'. Describe it in Bengali."
                return self.query_text(prompt)
            except Exception as e:
                log.error(f"Vision Error: {e}")
                time.sleep(2)
        return "😊 আমি ছবিটি ঠিকমতো বুঝতে পারছি না।"

jarvis = JarvisAI()

def get_local_stats(text: str) -> str:
    """ডিভাইস কন্ট্রোল কমান্ডসমূহ"""
    text = text.lower()
    if any(w in text for w in ["সময়", "time", "বাজে"]):
        return f"⏰ স্যার, এখন সময় {datetime.now().strftime('%I:%M %p')}।"
    
    if any(w in text for w in ["battery", "চার্জ", "charge"]):
        try:
            res = subprocess.run(['termux-battery-status'], capture_output=True, text=True)
            data = json.loads(res.stdout)
            return f"🔋 বর্তমানে চার্জ আছে {data.get('percentage')}% এবং অবস্থা {data.get('status')}।"
        except:
            return "❌ ব্যাটারি তথ্য পেতে Termux:API লাগবে।"
            
    if any(w in text for w in ["ram", "মেমোরি"]):
        try:
            res = subprocess.run(['free', '-m'], capture_output=True, text=True)
            return f"💾 সিস্টেম মেমোরি স্ট্যাটাস:\n`{res.stdout}`"
        except: return "❌ র‍্যাম তথ্য পাওয়া যায়নি।"
        
    return None

